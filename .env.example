# URL del API Spring Boot (solo servidor Next: Route Handlers / BFF).
SENTINELLA_API_URL=http://localhost:8080

# Origen WebSocket del backend (handshake ?token=JWT).
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080

# CORS en Spring: app.cors.allowed-origins debe incluir el origen del front (p. ej. http://localhost:3000).
